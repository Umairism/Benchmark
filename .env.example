# Supabase Configuration
# Copy this file to .env and fill in your actual Supabase credentials

# Supabase URL - Get this from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key - Get this from your Supabase project dashboard
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Set to 'development' to force local storage mode for testing
VITE_APP_MODE=production
